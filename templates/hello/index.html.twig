{% extends 'base.html.twig' %}

{% block title %}Hello Symfony!{% endblock %}

{% block body %}
<style>
    .example-wrapper {
        margin: 1em auto;
        max-width: 800px;
        width: 95%;
        font: 18px/1.5 sans-serif;
    }
    .example-wrapper code {
        background: #F5F5F5;
        padding: 2px 6px;
    }
    .highlight {
        color: #4CAF50;
        font-weight: bold;
    }
</style>

<div class="example-wrapper">
    <h1>{{ message }}</h1>
</div>
{% endblock %}